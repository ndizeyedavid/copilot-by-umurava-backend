          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "weights": {
          "type": "object",
          "properties": {
            "skills": {
              "type": "number"
            },
            "experience": {
              "type": "number"
            },
            "education": {
              "type": "number"
            }
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Screening": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string"
        },
        "jobId": {
          "type": "string"
        },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "candidateId": {
                "type": "string"
              },
              "matchScore": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              },
              "confidence": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              },
              "strengths": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "gaps": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reasoning": {
                "type": "string"
              },
              "finalRecommendation": {
                "type": "string",
                "enum": ["Strong hire", "Consider", "Weak fit", "Reject"]
              },
              "comparisonNotes": {
                "type": "string"
              },
              "rank": {
                "type": "number"
              }
            }
          }
        },
        "comparisonSummary": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Application": {
