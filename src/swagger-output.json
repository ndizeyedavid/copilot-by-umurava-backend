          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "screeningId": {
          "type": "string"
        },
        "appliedAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
