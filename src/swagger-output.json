                "talentId": {
                  "type": "string",
                  "example": "6618f5a2b4d3c2e1f0a9b8c8"
                },
                "coverLetter": { "type": "string" },
                "resumeUrl": { "type": "string" }
              },
              "required": ["jobId", "talentId"]
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Application submitted",
            "schema": {
              "type": "object",
              "properties": {
                "message": { "type": "string" },
                "application": { "$ref": "#/definitions/Application" }
              }
            }
          },
          "409": { "description": "Already applied" },
          "500": { "description": "Internal Server Error" }
        }
      }
    },
