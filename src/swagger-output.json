    "/screening/ai/{jobId}": {
      "post": {
        "tags": ["AI Screening"],
        "summary": "Run AI-powered candidate screening",
        "description": "Uses Gemini AI to evaluate and rank all applicants for a job. Automatically fetches applicants from Applications collection, runs AI evaluation, and updates application statuses.",
        "parameters": [
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "type": "string",
            "description": "MongoDB ID of the job to screen applicants for",
            "example": "6618f5a2b4d3c2e1f0a9b8c7"
          }
        ],
        "responses": {
          "200": {
            "description": "AI screening complete",
            "schema": {
              "type": "object",
              "properties": {
                "message": { "type": "string" },
                "screening": { "$ref": "#/definitions/Screening" },
                "applicantsScreened": { "type": "number" }
              }
            },
            "examples": {
              "application/json": {
                "message": "AI screening complete. 3 applicants ranked",
                "applicantsScreened": 3,
                "screening": {
                  "_id": "6629a6b3c5d4e3f2a1b0c9d8",
                  "jobId": "6618f5a2b4d3c2e1f0a9b8c7",
                  "candidates": [
                    {
                      "candidateId": "6618f5a2b4d3c2e1f0a9b8c8",
                      "rank": 1,
                      "matchScore": 92,
                      "confidence": "high",
                      "strengths": [
                        "5+ years React",
                        "Node.js expertise",
                        "AWS certification"
                      ],
                      "gaps": ["No Python experience"],
                      "reasoning": "Strong full-stack background aligns perfectly with job requirements. AWS cert adds value.",
                      "finalRecommendation": "Strong hire"
                    },
                    {
                      "candidateId": "6618f5a2b4d3c2e1f0a9b8c9",
                      "rank": 2,
                      "matchScore": 78,
                      "confidence": "medium",
                      "strengths": [
                        "Strong backend skills",
                        "Database optimization"
                      ],
                      "gaps": [
                        "Limited frontend experience",
                        "No cloud skills"
                      ],
                      "reasoning": "Solid backend developer but lacks frontend experience required for this full-stack role.",
                      "finalRecommendation": "Consider"
                    }
                  ],
                  "comparisonSummary": "Candidate 1 is the clear top choice with full-stack expertise. Candidate 2 is backend-focused and would need frontend upskilling.",
                  "createdAt": "2024-04-12T10:30:00.000Z",
                  "updatedAt": "2024-04-12T10:30:00.000Z"
                }
              }
            }
          },
          "400": { "description": "No applicants found for this job" },
          "404": { "description": "Job not found" },
          "500": { "description": "AI screening failed" }
        }
      }
    },
